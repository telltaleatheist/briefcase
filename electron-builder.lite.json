{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.owenmorgan.briefcase",
  "productName": "Briefcase",
  "asar": true,
  "compression": "normal",
  "afterPack": "./scripts/afterPack.js",
  "directories": {
    "output": "dist-electron",
    "buildResources": "assets"
  },
  "extraResources": [
    {
      "from": "assets",
      "to": "assets",
      "filter": [
        "tray-icon-*.png",
        "tray-icon-*.ico",
        "manifest.json"
      ]
    },
    {
      "from": "backend/node_modules",
      "to": "backend/node_modules",
      "filter": [
        "**/*",
        "!@ffmpeg-installer/**",
        "!@ffprobe-installer/**"
      ]
    },
    {
      "from": "backend/dist",
      "to": "backend/dist"
    },
    {
      "from": "dist-electron/shared",
      "to": "dist-electron/shared",
      "filter": [
        "**/*"
      ]
    }
  ],
  "files": [
    "dist-electron/electron/**/*",
    "dist-electron/config/**/*",
    "dist-electron/utilities/**/*",
    "dist-electron/shared/**/*",
    "!dist-electron/**/*.map",
    "!backend/**",
    "frontend-v3/dist/frontend-v3/**/*",
    "!utilities/**",
    "node_modules/**/*",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/*.md",
    "!**/node_modules/**/*.d.ts",
    "!**/node_modules/**/*.map",
    "!**/node_modules/**/LICENSE*",
    "!**/node_modules/**/license*",
    "!**/node_modules/**/docs/**",
    "!**/node_modules/**/example*/**",
    "!**/node_modules/**/coverage/**",
    "!**/node_modules/**/*.ts",
    "!**/node_modules/**/README*",
    "!**/node_modules/**/CHANGELOG*",
    "!**/node_modules/@ffmpeg-installer/**",
    "!**/node_modules/@ffprobe-installer/**"
  ],
  "asarUnpack": [
    "utilities/**"
  ],
  "mac": {
    "category": "public.app-category.utilities",
    "icon": "assets/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      }
    ],
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "assets/entitlements.mac.plist",
    "entitlementsInherit": "assets/entitlements.mac.plist",
    "artifactName": "${productName}-Lite-${version}-${arch}.${ext}",
    "extraResources": [],
    "extendInfo": {
      "LSUIElement": false
    }
  },
  "dmg": {
    "format": "ULFO",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "icon": "assets/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Lite-Setup-${version}.${ext}",
    "extraResources": []
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "deleteAppDataOnUninstall": false,
    "runAfterFinish": true,
    "displayLanguageSelector": false,
    "artifactName": "${productName}-Lite-Setup-${version}.${ext}",
    "include": "assets/installer.nsh",
    "warningsAsErrors": false,
    "packElevateHelper": true,
    "differentialPackage": false
  },
  "linux": {
    "icon": "assets/icon.png",
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility",
    "artifactName": "${productName}-Lite-${version}.${ext}",
    "extraResources": []
  },
  "publish": {
    "provider": "github",
    "releaseType": "release"
  }
}
